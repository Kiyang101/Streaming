# Port the standalone RTMP/HLS media server listens on for HLS output is handled in-process.
# RTMP ingest port:
RTMP_PORT=1935
# Allowed live stream key (only this key may publish):
LIVE_STREAM_KEY=devkey

# 4K AI upscaling (optional) — absolute path to the realesrgan-ncnn-vulkan binary
# and its models directory. See README "4K AI upscaling" for how to install them.
# REALESRGAN_PATH=/Users/you/tools/realesrgan/realesrgan-ncnn-vulkan
# REALESRGAN_MODELS=/Users/you/tools/realesrgan/models
